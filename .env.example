# ==================== SECRETS (keep these in .env) ====================
# These are sensitive values that should NEVER be in version control
# Copy this file to .env and fill in your actual secret values

# Google API Key for Gemini
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Chainlit Authentication Secret (used to sign auth tokens)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
CHAINLIT_AUTH_SECRET=your_chainlit_auth_secret_here

# Google OAuth Credentials
# Get these from: https://console.developers.google.com/apis/credentials
# Follow instructions in docs/GOOGLE_OAUTH_SETUP.md
OAUTH_GOOGLE_CLIENT_ID=your_oauth_client_id_here.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your_oauth_client_secret_here


# ==================== CONFIGURATION (defaults in config/settings.py) ====================
# These are non-secret configuration values with defaults in config/settings.py
# View all defaults in: config/settings.py
# Uncomment any of these to override the defaults

# Root Data Directory for Persistent Storage (default: ./data locally, /app/data in production)
# DATA_DIR=./data

# Directory for importing CSVs
# IMPORT_DIR=./data/import

# Gemini Embedding Model
# EMBEDDINGS_MODEL=models/gemini-embedding-2-preview
# DATA_DIR=./data

# PostgreSQL Database URLs (Required)
# Points to production DB even for local dev
# Option 1: Chainlit Data Layer AsyncPG
# DATABASE_URL=postgresql+asyncpg://user:password@hostname:5432/dbname
# Option 2: LangGraph / psycopg Checkpoint DB
# CHECKPOINT_DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# OAuth Domain Restriction (default: mooball.net,eagle-exports.com)
# OAUTH_ALLOWED_DOMAINS=yourdomain.com,anotherdomain.com

# Default Model (default: gemini-3-flash-preview)
# DEFAULT_MODEL=gemini-3-flash-preview

# LangGraph Execution Limit (default: 50)
# GRAPH_RECURSION_LIMIT=50

# Temporary files folder (default: .files)
# TEMP_FILES_FOLDER=.files

# Chainlit URL (default: http://localhost:8000)
# Required if behind reverse proxy or in production
# CHAINLIT_URL=https://yourdomain.com

