# Python virtual environment and cache
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Environment and secrets (never in container)
.env
service-account-key.json
*.json
config/mcp_servers.yaml

# Local runtime data
# NOTE: .chainlit/ is required to configure unsafe_allow_html
.files/
temp_files/
chainlit_datalayer.db
chainlit.db
*.db

# Git and CI/CD
.git/
.github/
.gitignore

# Development tools and tests
tests/
run_tests.sh
# Note: scripts/ is needed for database initialization in Cloud Run

# Documentation (except chainlit.md which Chainlit needs at runtime)
*.md
!chainlit.md
docs/

# macOS
.DS_Store

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
