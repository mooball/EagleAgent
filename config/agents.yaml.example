# Agent definitions and routing rules

agents:
  # The GeneralAgent is the fallback for general conversation
  general_agent:
    name: "GeneralAgent"
    description: "Use for general conversation, memory retrieval, task planning, document summarization."
    tools: ["user_profile", "mcp_tools"]
    fallback: true
  
  # BrowserAgent specialized for web tasks
  browser_agent:
    name: "BrowserAgent"
    description: "Use for web search, web automation, opening URLs, finding live information online."
    tools: ["browser_tools"]
    keywords: ["search", "browse", "website", "url", "http", "google", "find online"]

