# ================================================================
# Google Cloud Run Environment Configuration Template
# ================================================================
# 
# This file documents the environment variables needed for Cloud Run.
# DO NOT commit actual values to version control.
# 
# In production, these should be set via:
# 1. Secret Manager (for sensitive values)
# 2. Cloud Run environment variables (for non-sensitive config)
# 3. GitHub Actions secrets (for CI/CD)
#
# ================================================================

# ----------------------------------------------------------------
# LLM Configuration
# ----------------------------------------------------------------
# Google Gemini API key
# Store in Secret Manager: gcloud secrets create GOOGLE_API_KEY --data-file=-
GOOGLE_API_KEY=<secret-manager>

# ----------------------------------------------------------------
# GCP Project Configuration
# ----------------------------------------------------------------
# GCP project ID
GOOGLE_PROJECT_ID=your-project-id

# GCS bucket name for file storage
GCP_BUCKET_NAME=eagleagent-data

# ----------------------------------------------------------------
# Authentication & OAuth
# ----------------------------------------------------------------
# Chainlit session secret (generate with: openssl rand -hex 32)
# Store in Secret Manager
CHAINLIT_AUTH_SECRET=<secret-manager>

# Google OAuth client credentials
# Store in Secret Manager
OAUTH_GOOGLE_CLIENT_ID=<secret-manager>
OAUTH_GOOGLE_CLIENT_SECRET=<secret-manager>

# Allowed email domains for OAuth login (comma-separated)
# Store in Secret Manager or set directly
OAUTH_ALLOWED_DOMAINS=yourdomain.com

# ----------------------------------------------------------------
# Deployment Configuration
# ----------------------------------------------------------------
# Public URL of the Cloud Run service
# Set this AFTER first deployment, then update service
# Example: https://eagleagent-abc123-uc.a.run.app
CHAINLIT_URL=https://eagleagent-xyz.run.app

# HTTP port (automatically set by Cloud Run, usually 8080)
PORT=8080

# ----------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------
# SQLite database on GCSFuse mounted volume
# Path must be on /data mount point for persistence
# IMPORTANT: Use aiosqlite for async support
DATABASE_URL=sqlite+aiosqlite:////data/database/chainlit_datalayer.db

# ----------------------------------------------------------------
# File Storage Configuration
# ----------------------------------------------------------------
# Temporary file uploads folder (ephemeral, cleared on restart)
TEMP_FILES_FOLDER=/tmp/files

# ----------------------------------------------------------------
# MCP (Model Context Protocol) Configuration
# ----------------------------------------------------------------
# Directory for Google Workspace MCP OAuth credentials
# These credentials are pre-populated to /data on GCS mount
# Optional: only needed if using google-workspace-mcp
WORKSPACE_MCP_CREDENTIALS_DIR=/data/mcp_credentials/google_workspace

# ----------------------------------------------------------------
# Credentials (Cloud Run handles automatically)
# ----------------------------------------------------------------
# DO NOT SET in Cloud Run - uses Application Default Credentials
# Only needed for local development outside Cloud Run
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ----------------------------------------------------------------
# Example: Full gcloud deploy command with env vars
# ----------------------------------------------------------------
# gcloud run deploy eagleagent \
#   --source . \
#   --region australia-southeast1 \
#   --execution-environment gen2 \
#   --memory 2Gi \
#   --cpu 2 \
#   --min-instances 0 \
#   --max-instances 10 \
#   --timeout 300s \
#   --service-account eagleagent-runner@PROJECT.iam.gserviceaccount.com \
#   --allow-unauthenticated \
#   --add-volume name=gcs-data,type=cloud-storage,bucket=eagleagent-data \
#   --add-volume-mount volume=gcs-data,mount-path=/data \
#   --set-env-vars "GOOGLE_API_KEY=${GOOGLE_API_KEY}" \
#   --set-env-vars "CHAINLIT_AUTH_SECRET=${CHAINLIT_AUTH_SECRET}" \
#   --set-env-vars "OAUTH_GOOGLE_CLIENT_ID=${OAUTH_CLIENT_ID}" \
#   --set-env-vars "OAUTH_GOOGLE_CLIENT_SECRET=${OAUTH_CLIENT_SECRET}" \
#   --set-env-vars "OAUTH_ALLOWED_DOMAINS=yourdomain.com" \
#   --set-env-vars "GOOGLE_PROJECT_ID=your-project-id" \
#   --set-env-vars "GCP_BUCKET_NAME=eagleagent-data" \
#   --set-env-vars "DATABASE_URL=sqlite+aiosqlite:////data/database/chainlit_datalayer.db" \
#   --set-env-vars "TEMP_FILES_FOLDER=/tmp/files" \
#   --set-env-vars "WORKSPACE_MCP_CREDENTIALS_DIR=/data/mcp_credentials/google_workspace"
