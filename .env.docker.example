# Docker Local Testing Environment Variables
# Copy this file to .env.docker and fill in actual values
# DO NOT commit .env.docker to version control

# ----------------------------------------------------------------
# Copy these from your .env file
# ----------------------------------------------------------------
GOOGLE_API_KEY=your-gemini-api-key-here
CHAINLIT_AUTH_SECRET=your-64-char-auth-secret-here
OAUTH_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=GOCSPX-your-oauth-client-secret
OAUTH_ALLOWED_DOMAINS=yourdomain.com

# ----------------------------------------------------------------
# Docker-specific configuration (use as-is)
# ----------------------------------------------------------------

# GCP Project (test project for local Firestore emulator)
GOOGLE_PROJECT_ID=test-project

# Deployment
CHAINLIT_URL=http://localhost:8080
PORT=8080

# Database (using Docker volume mount at /app/data)
DATABASE_URL=sqlite+aiosqlite:////app/data/database/chainlit_datalayer.db

# Storage  
GCP_BUCKET_NAME=eagleagent
TEMP_FILES_FOLDER=/tmp/files

# Firestore Emulator
# Mac/Windows: use host.docker.internal
# Linux: use 172.17.0.1
FIRESTORE_EMULATOR_HOST=host.docker.internal:8686

# ----------------------------------------------------------------
# DO NOT SET - Container uses Application Default Credentials
# ----------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS is intentionally not set
